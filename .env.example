# Thesis Dashboard Environment Variables

# Server Configuration
PORT=3001

# API Keys (optional - fallbacks available for most APIs)

# FRED (Federal Reserve Economic Data) - Free, signup at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=demo

# Alpha Vantage (backup for market data) - Free tier, signup at https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=

# EIA (Energy Information Administration) - Free, signup at https://www.eia.gov/opendata/register.php
EIA_API_KEY=

# ERCOT API (Energy market data) - Register at https://apiexplorer.ercot.com/
# Required for live ERCOT pricing. Mock data is used as fallback when not configured.
ERCOT_API_USERNAME=
ERCOT_API_PASSWORD=
ERCOT_API_SUBSCRIPTION_KEY=

# CoinGecko Pro (optional, free tier works without key)
COINGECKO_API_KEY=

# Glassnode (for advanced Bitcoin analytics - paid)
GLASSNODE_API_KEY=

# Webhook URLs for alerts (optional)
DISCORD_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Database path (default: ./data/cache.db)
DATABASE_PATH=./data/cache.db

# SanghaModel API (Bitcoin mining risk simulator)
# Base URL of the SanghaModel FastAPI service
SANGHAMODEL_BASE_URL=http://localhost:8100
# Bearer token for SanghaModel API authentication
SANGHAMODEL_API_KEY=sm_dev_key_12345
