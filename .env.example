# Thesis Dashboard Environment Variables

# Server Configuration
PORT=3001

# API Keys (optional - fallbacks available for most APIs)

# FRED (Federal Reserve Economic Data) - Free, signup at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=demo

# Alpha Vantage (backup for market data) - Free tier, signup at https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=

# EIA (Energy Information Administration) - Free, signup at https://www.eia.gov/opendata/register.php
EIA_API_KEY=

# CoinGecko Pro (optional, free tier works without key)
COINGECKO_API_KEY=

# Glassnode (for advanced Bitcoin analytics - paid)
GLASSNODE_API_KEY=

# Webhook URLs for alerts (optional)
DISCORD_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Database path (default: ./data/cache.db)
DATABASE_PATH=./data/cache.db
